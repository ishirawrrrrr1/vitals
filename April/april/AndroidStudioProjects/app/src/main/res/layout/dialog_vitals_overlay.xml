<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0F172A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CLINICAL VITAL DATA CAPTURE"
        android:textColor="#38BDF8"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HEART RATE" android:textColor="#94A3B8" android:textSize="10sp"/>
            <TextView android:id="@+id/dlgHeartRate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#F43F5E" android:textSize="32sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SPO2" android:textColor="#94A3B8" android:textSize="10sp"/>
            <TextView android:id="@+id/dlgSpo2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#38BDF8" android:textSize="32sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TEMP" android:textColor="#94A3B8" android:textSize="10sp"/>
            <TextView android:id="@+id/dlgTemp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#FB923C" android:textSize="32sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BP" android:textColor="#94A3B8" android:textSize="10sp"/>
            <TextView android:id="@+id/dlgBP" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="#C084FC" android:textSize="32sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/dlgStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SESSION ACTIVE"
        android:textColor="#22C55E"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:background="#166534"
        android:padding="8dp"/>

</LinearLayout>
